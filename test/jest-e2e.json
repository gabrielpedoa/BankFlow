{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "maxWorkers": 1,
  "resetModules": false,
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1",
    "^@accounts/(.*)$": "<rootDir>/src/modules/accounts/$1"
  }
}
